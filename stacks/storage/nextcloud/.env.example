# ==============================================================================
# Nextcloud Stack Environment Variables (Example)
# ==============================================================================
#
# This file is provided as an example/template only.
#
# Replace all example values with values appropriate for your environment before
# deployment. Do not commit real passwords, API keys, tokens, or other secrets
# to source control.
#
# Secret values should be stored in dedicated secret files and referenced using
# *_FILE variables where supported.
#
# ==============================================================================

# Change the values below

NEXTCLOUD_CONTAINER_NAME=nextcloud
NEXTCLOUD_DB_CONTAINER_NAME=database
NEXTCLOUD_REDIS_CONTAINER_NAME=redis
NEXTCLOUD_CRON_CONTAINER_NAME=cron

NEXTCLOUD_TRUSTED_PROXIES=172.X.X.X/16
NEXTCLOUD_HOST=nextcloud.example.com

NEXTCLOUD_ADMIN_USER=admin

NEXTCLOUD_DATA_DIR=/home/user/homelab/data/nextcloud
NEXTCLOUD_LOGS_DIR=/home/user/homelab/logs/nextcloud

NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud

NEXTCLOUD_DB_PASSWORD_FILE=/home/user/homelab/secrets/databases/nextcloud-password
NEXTCLOUD_ADMIN_PASSWORD_FILE=/home/user/homelab/secrets/nextcloud/admin-password
