# Copy this file to .env and customise as needed.

# --------------------------------------------------
# Core project settings
# --------------------------------------------------
COMPOSE_PROJECT_NAME=homelab
PUID=1000
PGID=1000
TZ=Australia/Brisbane

# --------------------------------------------------
# Cloudflare
# --------------------------------------------------
CF_TUNNEL_TOKEN=<insert_secret_token>

# --------------------------------------------------
# Traefik / routing
# --------------------------------------------------
TRAEFIK_DASHBOARD_HOST=traefik.internal
PORTAINER_HOST=portainer.internal
PROMETHEUS_HOST=prometheus.internal
GRAFANA_HOST=grafana.internal

WEBSITE_HOST=lab.dylanskelly.com
VAULTWARDEN_HOST=vault.dylanskelly.com
NEXTCLOUD_HOST=cloud.dylanskelly.com
GITEA_HOST=git.dylanskelly.com
TEST_SITE_HOST=test.lab.dylanskelly.com
DEMO_SITE_HOST=demo.lab.dylanskelly.com

# --------------------------------------------------
# Grafana
# --------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<insert_secret_token>

# --------------------------------------------------
# Vaultwarden
# --------------------------------------------------
VAULTWARDEN_ADMIN_TOKEN=<insert_secret_token>
VAULTWARDEN_SIGNUPS_ALLOWED=false

# --------------------------------------------------
# Nextcloud
# --------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=<insert_secret_token>
